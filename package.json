{
  "name": "milo-dsl",
  "version": "0.1.0",
  "description": "TypeScript DSL for authoring interactive narrative JSON.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "milo-dsl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc -p tsconfig.build.json",
    "example:build": "bun run build.ts"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YaquilunaDev/milo-dsl.git"
  },
  "bugs": {
    "url": "https://github.com/YaquilunaDev/milo-dsl/issues"
  },
  "homepage": "https://github.com/YaquilunaDev/milo-dsl#readme",
  "license": "GPL-3.0-only",
  "keywords": [
    "dsl",
    "typescript",
    "interactive-narrative",
    "bun"
  ],
  "dependencies": {
    "esbuild": "^0.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
